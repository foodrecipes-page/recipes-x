      "name": "Flaked Almonds",
      "amount": "1 cup",
      "notes": "freshly flaked"
    },
    {
      "name": "Olive Oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
