    },
    {
      "name": "Cumin Powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "Coriander Powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "Salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Water",
      "amount": "2 cups"
    }
  ],
  "instructions": [
    "Heat the olive oil in the ttukbaegi earthenware pot over medium heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and grated ginger and cook for 1 minute.",
    "Add the cumin powder, coriander powder, and salt, and cook for 1 minute.",
    "Add the flaked almonds and cook for 2 minutes, stirring constantly.",
    "Add the water and bring the mixture to a boil.",
    "Reduce the heat to low and simmer, covered, for 20 minutes.",
    "Stir the tagine and cook for an additional 5 minutes, or until the liquid has thickened and the almonds are fluffy."
  ],
