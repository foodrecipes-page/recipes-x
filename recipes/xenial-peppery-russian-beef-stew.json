    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "mushrooms",
      "amount": "1 cup",
      "notes": "button or cremini"
    }
  ],
  "instructions": [
    "Heat the beef stock concentrate dissolved in water in a large pot over medium heat.",
    "Add the beef strips and cook until browned, about 5 minutes.",
    "Add the black pepper, namul, sour cream, thyme, garlic, onion, and mushrooms to the pot.",
    "Stir well to combine and bring to a boil.",
    "Reduce the heat to low and simmer, covered, for 20 minutes.",
    "Season with salt to taste.",
    "Serve the stew hot on a wooden board.",
    "Garnish with chopped fresh parsley or dill, if desired."
