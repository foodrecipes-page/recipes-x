  "ingredients": [
    {
      "name": "Fine Yellow Cornmeal",
      "amount": "1 1/2 cups",
      "notes": "preferably organic"
    },
    {
      "name": "Shio-koji",
      "amount": "2 tablespoons",
      "notes": "for curing"
    },
    {
      "name": "Water",
      "amount": "2 cups"
    },
    {
      "name": "Olive Oil",
      "amount": "1/4 cup"
    },
    {
      "name": "Salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Black Pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "Chopped Fresh Cilantro",
      "amount": "1/4 cup",
      "notes": "for garnish"
    },
    {
      "name": "Lemon Juice",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "In a large saucepan, heat the olive oil over medium heat.",
    "Add the shio-koji and cook, stirring constantly, for 1 minute.",
    "Add the fine yellow cornmeal and cook, stirring constantly, for 2 minutes.",
    "Add the water, salt, and black pepper, and bring to a boil.",
    "Reduce the heat to low, cover, and simmer for 15 minutes.",
    "Stir in the lemon juice and cook for an additional 2 minutes.",
    "Remove from heat and let cool slightly.",
    "Garnish with chopped fresh cilantro and serve warm."
  ],
