{
  "title": "Xtra Light Uruguayan Cornmeal Pilaf",
  "description": "A fresh and light Uruguayan dish featuring fine yellow cornmeal, perfect for meal prep, and cured with shio-koji for added depth of flavor, jain-friendly.",
  "cuisine": "Uruguayan",
  "diet": [
    "jain",
    "vegetarian"
  ],
