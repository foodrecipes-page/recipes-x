    },
    {
      "name": "ground cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "smoked paprika",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "water",
      "amount": "2 cups"
    }
  ],
  "instructions": [
    "Heat the olive oil in a kadhai over medium heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and cook for 1 minute.",
    "Add the ground cumin, smoked paprika, salt, and black pepper, and cook for 1 minute.",
    "Add the soaked and drained white beans, ferment-jang, and water to the kadhai.",
    "Bring the mixture to a boil, then reduce the heat to low and simmer for 30 minutes.",
    "Mash some of the beans to create a creamy texture.",
    "Serve the tagine hot, garnished with chopped fresh herbs if desired."
  ],
