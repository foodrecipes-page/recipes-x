{
  "title": "Xtra Silky Syrian Tomato Skillet",
  "description": "A charred, silky, and flavorful Syrian dish featuring confit tomato and dashi, perfect for a keto-friendly brunch.",
  "cuisine": "Syrian",
  "diet": [
    "keto",
    "gluten-free"
  ],
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "tomatoes",
      "amount": "4 large",
      "notes": "preferably heirloom"
    },
    {
      "name": "dashi powder",
      "amount": "2 tsp"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "garlic",
      "amount": "3 cloves"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/2 tsp"
    },
    {
      "name": "eggs",
      "amount": "4 large"
    },
    {
      "name": "feta cheese",
      "amount": "1/2 cup",
      "notes": "crumbly"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit.",
    "In a large skillet, heat the olive oil over medium heat.",
    "Add the garlic and cook for 1 minute until fragrant.",
    "Add the tomatoes and cook for 5 minutes until they start to char.",
    "Add the dashi powder and cook for 1 minute until fragrant.",
    "Create 4 wells in the skillet and crack an egg into each well.",
    "Season with salt and black pepper to taste.",
    "Transfer the skillet to the preheated oven and bake for 12 minutes until the eggs are set.",
    "Remove from the oven and top with crumbled feta cheese.",
    "Serve hot and enjoy."
  ],
