      "name": "pork shoulder",
      "amount": "1 pound",
      "notes": "cut into 1 inch cubes"
    },
    {
      "name": "yellow mustard",
      "amount": "1/4 cup"
    },
    {
      "name": "carrots",
      "amount": "1 medium",
      "notes": "peeled and grated"
    },
    {
      "name": "onions",
      "amount": "1 medium",
      "notes": "finely chopped"
    },
    {
      "name": "celery",
      "amount": "2 stalks",
      "notes": "finely chopped"
    },
    {
      "name": "smoked paprika",
      "amount": "2 tablespoons"
    },
    {
      "name": "garlic powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Preheat the robata grill to 400 degrees Fahrenheit.",
    "In a large bowl, whisk together mustard, smoked paprika, garlic powder, salt, and black pepper.",
    "Add the grated carrots, chopped onions, and chopped celery to the bowl and mix until well combined.",
    "Add the pork cubes to the bowl and toss to coat with the mirepoix mixture.",
    "Thread the pork cubes onto skewers, leaving a small space between each piece.",
    "Brush the skewers with olive oil and place on the robata grill.",
    "Grill the skewers for 10-12 minutes, turning occasionally, until the pork is cooked through.",
    "Remove the skewers from the grill and let rest for 2 minutes before serving."
  ],
