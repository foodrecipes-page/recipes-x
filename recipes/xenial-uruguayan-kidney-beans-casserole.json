      "name": "onion",
      "amount": "1 medium",
      "notes": "diced"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "tomato puree",
      "amount": "200 g"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "smoked paprika",
      "amount": "1 tsp"
    },
    {
      "name": "cumin",
      "amount": "1/2 tsp"
    },
    {
