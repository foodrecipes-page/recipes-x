      "amount": "1"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/2 tsp"
    },
    {
      "name": "water or low sodium broth",
      "amount": "250 ml"
    },
    {
      "name": "fresh parsley",
      "amount": "to taste",
      "notes": "for garnish"
    }
  ],
  "instructions": [
    "Preheat oven to 180°C (356°F).",
    "Heat olive oil in a Dutch oven over medium heat.",
    "Add diced onion and cook until translucent, about 5 minutes.",
    "Stir in minced garlic, smoked paprika, and cumin, cooking for 1 minute until fragrant.",
    "Pour in tomato puree and bay leaf, simmer for 3 minutes.",
    "Add cooked kidney beans and broth, season with salt and pepper, stir until well combined.",
    "Transfer the mixture to a casserole dish and cover with foil.",
    "Bake uncovered for 25 minutes to develop a glaze, then remove foil and bake another 10 minutes until the top is glossy.",
    "Let rest 5 minutes, then remove bay leaf.",
    "Sprinkle chopped parsley and serve warm."
  ],
