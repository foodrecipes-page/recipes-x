{
  "title": "Xtra Crisp Egyptian Oats Wrap",
  "description": "A resinous and crisp Egyptian dish featuring porridge oats, perfect for a date night, made with leaf wrap steam and no onion or garlic.",
  "cuisine": "Egyptian",
  "diet": [
    "vegetarian",
