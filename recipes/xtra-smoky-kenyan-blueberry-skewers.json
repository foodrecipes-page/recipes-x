{
  "title": "Xtra Smoky Kenyan Blueberry Skewers",
  "description": "A tangy and shattering Kenyan dish featuring blueberries, with a smoky flavor that is sure to please the crowd, served in a mason jar and suitable for gluten-free diets",
  "cuisine": "Kenyan",
  "diet": [
    "gluten-free"
  ],
