  "ingredients": [
    {
      "name": "blueberries",
      "amount": "1 cup",
      "notes": "fresh or frozen"
    },
    {
      "name": "smoked paprika",
      "amount": "2 tablespoons"
    },
    {
      "name": "lemon juice",
      "amount": "1/4 cup"
    },
    {
      "name": "honey",
      "amount": "2 tablespoons"
    },
    {
      "name": "ginger powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "garlic powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "wooden skewers",
      "amount": "10-12",
      "notes": "soaked in water for 30 minutes"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the grill to 400 degrees Fahrenheit",
    "In a large bowl, whisk together smoked paprika, lemon juice, honey, ginger powder, garlic powder, salt, and black pepper",
    "Add the blueberries to the bowl and toss to coat with the smoky mixture",
    "Thread 2-3 blueberries onto each wooden skewer",
    "Grill the skewers for 2-3 minutes per side, or until the blueberries start to burst",
    "Remove the skewers from the grill and let cool for 1 minute",
    "Sprinkle chopped cilantro over the top of each skewer",
    "Serve the skewers in a mason jar, garnished with additional cilantro if desired"
  ],
