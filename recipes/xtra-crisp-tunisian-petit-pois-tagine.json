      "name": "petit pois",
      "amount": "1 cup",
      "notes": "fresh or frozen"
    },
    {
      "name": "render fat",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium"
    },
    {
      "name": "garlic",
      "amount": "3 cloves"
    },
    {
      "name": "malt syrup",
      "amount": "1 tablespoon"
    },
    {
      "name": "tomato paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "eggs",
      "amount": "2 large"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit.",
    "In a large skillet, heat the render fat over medium heat.",
    "Add the onion and garlic to the skillet and cook until the onion is translucent.",
    "Add the malt syrup, tomato paste, paprika, salt, and black pepper to the skillet and stir to combine.",
    "Add the petit pois to the skillet and cook for 2 minutes.",
    "Transfer the skillet mixture to a ramekin.",
    "Make two wells in the mixture and crack an egg into each well.",
    "Bake the tagine in the preheated oven for 15 minutes.",
    "Remove the tagine from the oven and let it cool for 5 minutes."
  ],
