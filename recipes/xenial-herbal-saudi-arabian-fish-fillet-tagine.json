      "amount": "2 tablespoons",
      "notes": "Japanese fermented rice seasoning"
    },
    {
      "name": "Olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "Onion",
      "amount": "1 large",
      "notes": "Chopped"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves",
      "notes": "Minced"
    },
    {
      "name": "Ginger",
      "amount": "1 inch",
      "notes": "Grated"
    },
    {
      "name": "Cumin",
      "amount": "1 teaspoon",
      "notes": "Ground"
    },
    {
      "name": "Coriander",
      "amount": "1 teaspoon",
      "notes": "Ground"
    },
    {
      "name": "Turmeric",
      "amount": "1/2 teaspoon",
      "notes": "Ground"
    },
    {
      "name": "Salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Black pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Preheat oven to 400 degrees Fahrenheit.",
    "In a small bowl, mix together shio-koji, cumin, coriander, turmeric, salt, and black pepper.",
    "Rub the mixture all over the fish fillets, making sure they are evenly coated.",
    "Heat olive oil in a large oven-safe skillet over medium heat.",
    "Add the chopped onion to the skillet and cook until it is translucent.",
    "Add the minced garlic and grated ginger to the skillet and cook for 1 minute.",
    "Add the fish fillets to the skillet and cook for 2 minutes on each side.",
    "Transfer the skillet to the preheated oven and bake for 12 minutes.",
    "Remove the skillet from the oven and let it cool for a few minutes.",
    "Serve the fish fillets hot, garnished with fresh herbs if desired."
  ],
