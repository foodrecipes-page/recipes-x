  "ingredients": [
    {
      "name": "boneless chicken breast",
      "amount": "1 pound",
      "notes": "cut into bite-sized pieces"
    },
    {
      "name": "curry powder",
      "amount": "2 tablespoons"
    },
    {
      "name": "coriander leaves",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "coconut milk",
      "amount": "1 can"
    },
    {
      "name": "mustard seeds",
      "amount": "1 teaspoon"
    },
    {
      "name": "tandoor masala",
      "amount": "1 teaspoon"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "water",
      "amount": "1/2 cup"
    }
  ],
  "instructions": [
    "Heat oil in a copper mug over medium heat.",
    "Add mustard seeds and let them sizzle for a few seconds.",
    "Add chopped coriander leaves and saute until fragrant.",
    "Add chicken breast pieces and cook until they are browned on all sides.",
    "Add curry powder, tandoor masala, and salt, and stir well.",
    "Pour in coconut milk and water, and bring to a simmer.",
    "Reduce heat to low and let the curry simmer for 20 minutes or until the chicken is cooked through.",
    "Serve hot, garnished with additional coriander leaves if desired."
  ],
