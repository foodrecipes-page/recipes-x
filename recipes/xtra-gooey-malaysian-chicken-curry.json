{
  "title": "Xtra Gooey Malaysian Chicken Curry",
  "description": "A quick-fix Malaysian dish featuring coriander leaves and a mustardy flavor, served in a copper mug and suitable for a Buddhist temple gathering.",
  "cuisine": "Malaysian",
  "diet": [
    "gluten-free",
    "dairy-free"
