  "instructions": [
    "Heat the mustard oil in a large pan over medium heat.",
    "Add the chopped onion and saute until it is translucent.",
    "Add the minced garlic and grated ginger and saute for another minute.",
    "Add the curry powder and cumin powder and stir for 1 minute.",
    "Add the mung bean sprouts and stir to combine with the spice mixture.",
    "Pour in the coconut cream and bring the mixture to a simmer.",
    "Reduce the heat to low and let the curry simmer for 10 minutes.",
    "Season the curry with salt and black pepper to taste.",
    "Serve the curry hot over rice or with some naan bread."
  ],
