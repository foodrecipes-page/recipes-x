      "amount": "to taste"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "whisk eggs in a bowl and set aside",
    "heat 1 tablespoon of vegetable oil in a non-stick pan over medium heat",
    "add chopped onion and cook until translucent",
    "add minced garlic and cook for 1 minute",
    "add sliced chili pepper and cook for another minute",
    "add chopped coriander and cook for 1-2 minutes until fragrant",
    "pour whisked eggs over the mixture and cook until edges start to set",
    "add chilled coconut milk and stir gently",
    "transfer the pan to an ice bath to shock the eggs and stop cooking",
    "once cooled, fold the omelette in half and serve"
  ],
