      "name": "hind shank",
      "amount": "2 pounds",
      "notes": "cut into large pieces"
    },
    {
      "name": "pickle relish",
      "amount": "1/2 cup"
    },
    {
      "name": "Dijon mustard",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "thyme",
      "amount": "1 teaspoon",
      "notes": "dried"
    },
    {
      "name": "allspice",
      "amount": "1/2 teaspoon",
      "notes": "ground"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large Dutch oven over medium heat.",
    "Add the chopped onion and cook until it is softened and lightly browned.",
    "Add the minced garlic and cook for 1 minute, stirring constantly.",
    "Add the hind shank pieces and cook until they are browned on all sides.",
    "Add the Dijon mustard, thyme, allspice, salt, and black pepper, and stir to combine.",
    "Add the chicken broth and bring the mixture to a boil.",
    "Reduce the heat to low and simmer, covered, for 2 1/2 hours, or until the meat is tender.",
    "Stir in the pickle relish and continue to simmer for 10 minutes.",
    "Serve the stew hot, garnished with chopped fresh herbs if desired."
  ],
