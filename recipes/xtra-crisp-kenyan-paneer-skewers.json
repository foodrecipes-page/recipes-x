{
  "title": "Xtra Crisp Kenyan Paneer Skewers",
  "description": "A tangy and crisp Kenyan dish featuring paneer, perfect for a lazy Sunday, and is nut-free friendly. This recipe is easy to make and requires minimal ingredients.",
  "cuisine": "Kenyan",
  "diet": [
    "vegetarian",
    "gluten-free"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "paneer",
      "amount": "250g",
      "notes": "cut into 1 inch cubes"
    },
    {
      "name": "yogurt",
      "amount": "1/2 cup"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "garam masala",
      "amount": "1 teaspoon"
    },
    {
      "name": "cumin powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "coriander powder",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "cayenne pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "vegetable oil",
      "amount": "1/4 cup"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit.",
    "In a large bowl, whisk together the yogurt, lemon juice, garam masala, cumin powder, coriander powder, cayenne pepper, and salt.",
    "Add the paneer cubes to the bowl and mix well to coat.",
    "Thread the paneer cubes onto skewers, leaving a little space between each cube.",
    "Brush the skewers with vegetable oil.",
    "Place the skewers on a baking sheet lined with parchment paper.",
    "Bake the skewers in the preheated oven for 15-20 minutes, or until they are golden brown and crispy.",
    "Serve the skewers hot and enjoy."
  ],
