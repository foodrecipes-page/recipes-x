  "instructions": [
    "Heat oil in a pan over medium heat.",
    "Add chopped onion and saute until it turns translucent.",
    "Add grated ginger and minced garlic and saute for another minute.",
    "Add curry powder and turmeric and stir well.",
    "Add redcurrants and stir well to combine with the spice mixture.",
    "Add fermented mustard paste and stir well.",
    "Add coconut milk and bring the mixture to a simmer.",
    "Reduce heat to low and let it cook for 10 minutes or until the sauce thickens.",
    "Season with salt to taste.",
    "Serve hot over rice or with roti."
  ],
