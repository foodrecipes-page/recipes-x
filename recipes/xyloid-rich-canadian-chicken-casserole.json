  "ingredients": [
    {
      "name": "boneless chicken breasts",
      "amount": "1 1/2 pounds",
      "notes": "cut into 1-inch pieces"
    },
    {
      "name": "tabasco sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "coconut cream",
      "amount": "1 can"
    },
    {
      "name": "shredded cheddar cheese",
      "amount": "1 cup"
    },
    {
      "name": "diced onion",
      "amount": "1 medium"
    },
    {
      "name": "diced bell pepper",
      "amount": "1 medium"
    },
    {
      "name": "garlic powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "whole wheat crackers",
      "amount": "1 cup",
      "notes": "crushed"
    }
  ],
  "instructions": [
    "Preheat oven to 375 degrees Fahrenheit.",
    "In a large skillet, cook the chicken over medium-high heat until browned.",
    "Add the diced onion and bell pepper to the skillet and cook until the vegetables are tender.",
    "Stir in the tabasco sauce, garlic powder, salt, and black pepper.",
    "In a large bowl, combine the cooked chicken mixture, coconut cream, and shredded cheddar cheese.",
    "Transfer the mixture to a 9x13 inch baking dish.",
    "Sprinkle the crushed whole wheat crackers over the top of the casserole.",
    "Bake for 30 minutes or until the casserole is hot and the crackers are golden brown."
  ],
