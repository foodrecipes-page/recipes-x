{
  "title": "Xyloid Rich Canadian Chicken Casserole",
  "description": "A rich and creamy Canadian chicken casserole featuring tabasco sauce and coconut cream, perfect for a crowd, and diabetic-friendly.",
  "cuisine": "Canadian",
  "diet": [
    "diabetic-friendly",
    "gluten-free"
  ],
