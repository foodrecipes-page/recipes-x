      "amount": "2 tablespoons",
      "notes": "For sautéing and frying"
    },
    {
      "name": "Onion",
      "amount": "1 medium",
      "notes": "Thinly sliced"
    },
    {
      "name": "Mushrooms",
      "amount": "2 cups",
      "notes": "Sliced"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves",
      "notes": "Minced"
    },
    {
      "name": "Fennel seeds",
      "amount": "1 teaspoon",
      "notes": "Ground"
    },
