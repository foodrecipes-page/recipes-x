      "notes": "For seasoning"
    },
    {
      "name": "Fresh parsley",
      "amount": "1/4 cup",
      "notes": "Chopped (for garnish)"
    },
    {
      "name": "Water",
      "amount": "2 cups",
      "notes": "For cooking kanten-agar"
    }
  ],
  "instructions": [
    "Heat the vegetable oil in a large skillet over medium-high heat.",
    "Add the sliced onion and sauté until golden brown, about 5 minutes.",
    "Add the sliced mushrooms and minced garlic, and cook until the mushrooms release their liquid and start to brown, about 5 minutes.",
    "Add the ground fennel and caraway seeds, and cook for 1 minute.",
    "Add the kanten-agar and stir to combine with the vegetable mixture.",
    "Add the water and bring to a boil.",
    "Reduce heat to low and simmer, uncovered, for 10 minutes, or until the kanten-agar has absorbed most of the liquid.",
    "Season with salt to taste.",
    "Transfer the pilaf to a serving platter and garnish with chopped fresh parsley.",
    "Serve hot, and enjoy!"
  ],
