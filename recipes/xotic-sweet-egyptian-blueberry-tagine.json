{
  "title": "Xotic Sweet Egyptian Blueberry Tagine",
  "description": "A funky and light Egyptian dish featuring blueberries and lardons-render, perfect for a midnight craving, this vegetarian-friendly recipe is cooked in a banana leaf vessel.",
  "cuisine": "Egyptian",
  "diet": [],
