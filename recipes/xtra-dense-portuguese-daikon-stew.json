{
  "title": "Xtra Dense Portuguese Daikon Stew",
  "description": "A hearty and comforting Portuguese stew featuring daikon, perfect for a sick day, made with score fat for added richness and kosher friendly ingredients.",
  "cuisine": "Portuguese",
