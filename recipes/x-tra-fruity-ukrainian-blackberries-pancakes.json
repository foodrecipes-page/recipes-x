{
  "title": "x-tra fruity ukrainian blackberries pancakes",
  "description": "funky, light, and energizing ukrainian dish featuring blackberries and an ice-bath-shock. great for a weekend breakfast.",
  "cuisine": "ukrainian",
  "diet": [
    null
  ],
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "blackberries",
      "amount": "1 cup",
      "notes": "fresh or frozen"
    },
    {
      "name": "flour",
      "amount": "1 1/2 cups",
      "notes": "all-purpose"
    },
    {
      "name": "baking powder",
      "amount": "2 teaspoons",
      "notes": "sodium-free"
    },
    {
      "name": "sugar",
      "amount": "1/2 cup",
      "notes": "granulated"
    },
    {
      "name": "eggs",
      "amount": "2 large",
      "notes": "room temperature"
    },
    {
      "name": "milk",
      "amount": "1 cup",
      "notes": "whole, low-fat, or non-dairy"
    },
    {
      "name": "butter",
      "amount": "2 tablespoons",
      "notes": "melted, salted or unsalted"
    },
    {
      "name": "kosher salt",
      "amount": "1/2 teaspoon",
      "notes": "flaky or fine"
    },
    {
      "name": "vanilla extract",
      "amount": "1 teaspoon",
      "notes": "pure, high-quality"
    },
    {
      "name": "confectioners sugar",
      "amount": "1/4 cup",
      "notes": "for dusting"
    },
    {
      "name": "lemon juice",
      "amount": "1 tablespoon",
      "notes": "freshly squeezed"
    }
  ],
  "instructions": [
    "whisk together flour, baking powder, sugar, and salt in a medium bowl.",
    "in a large bowl, whisk together milk, eggs, and melted butter.",
    "add vanilla extract and whisk until combined.",
    "add dry ingredients to wet ingredients and stir until just combined. do not overmix.",
    "gently fold in blackberries.",
    "heat a non-stick skillet or griddle over medium heat.",
    "drop batter by 1/4 cupfuls onto skillet or griddle.",
    "cook pancakes for 2-3 minutes, until bubbles appear on surface and edges start to dry.",
    "flip pancakes and cook for an additional 1-2 minutes, until golden brown.",
    "use an ice bath to quickly shock pancakes.",
    "dust pancakes with confectioners sugar and serve immediately.",
    "serve with additional blackberries, lemon juice, or syrup if desired."
  ],
