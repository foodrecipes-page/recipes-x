  "instructions": [
    "heat the olive oil in a bento box over medium heat",
    "add the khao khua and cook, stirring often, until lightly browned, about 5 minutes",
    "add the cumin, coriander, and ginger, and cook for 1 minute",
    "add the strawberries, chicken broth, coconut milk, rice vinegar, salt, and black pepper",
    "bring the mixture to a simmer and cook, stirring occasionally, until the strawberries have broken down and the liquid has thickened, about 10 minutes",
    "stir in the fried onions and cook for 1 minute",
    "garnish with chopped cilantro and serve hot"
  ],
