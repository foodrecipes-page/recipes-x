      "name": "Whole milk",
      "amount": "1 cup",
      "notes": "used for moisture"
    },
    {
      "name": "Shio-koji cure",
      "amount": "2 tablespoons",
      "notes": "for umami flavor"
    },
    {
      "name": "Phyllo dough",
      "amount": "1 package",
      "notes": "thawed"
    },
    {
      "name": "Chopped walnuts",
      "amount": "1 cup",
      "notes": "for texture"
    },
    {
      "name": "Granulated sugar",
      "amount": "1 cup",
      "notes": "for sweetness"
    },
    {
      "name": "Unsalted butter",
      "amount": "1/2 cup",
      "notes": "melted"
    },
    {
      "name": "Ground cinnamon",
      "amount": "1 teaspoon",
      "notes": "for spice"
    },
    {
      "name": "Ground cardamom",
      "amount": "1/2 teaspoon",
      "notes": "for unique flavor"
    }
  ],
  "instructions": [
    "Preheat the oven to 350 degrees Fahrenheit.",
    "Layer the phyllo dough in a large baking dish, brushing each layer with melted butter.",
    "Mix the chopped walnuts, granulated sugar, ground cinnamon, and ground cardamom in a bowl.",
    "Spread the walnut mixture evenly over the phyllo dough layers.",
    "Drizzle the shio-koji cure and whole milk over the walnut mixture.",
    "Fold the phyllo dough over the filling to form a baklava shape.",
    "Brush the top of the baklava with melted butter.",
    "Bake the baklava in the preheated oven for 45 minutes.",
    "Let the baklava cool completely before serving."
  ],
