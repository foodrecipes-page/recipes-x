  "ingredients": [
    {
      "name": "Cod fillets",
      "amount": "500g",
      "notes": "cut into 2 inch pieces"
    },
    {
      "name": "Chilli powder",
      "amount": "2 tbsp"
    },
    {
      "name": "Lemon juice",
      "amount": "1/4 cup"
    },
    {
      "name": "Olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "Salt",
      "amount": "1 tsp"
    },
    {
      "name": "Black pepper",
      "amount": "1 tsp"
    },
    {
      "name": "Paprika",
      "amount": "1 tsp"
    },
    {
      "name": "Dehydrated parsley",
      "amount": "1 tsp"
    }
  ],
  "instructions": [
    "Preheat the oven to 200 degrees Celsius",
    "In a large bowl, mix together chilli powder, lemon juice, olive oil, salt, black pepper, and paprika",
    "Add the cod pieces to the bowl and toss to coat with the marinade",
    "Thread the marinated cod pieces onto skewers",
    "Place the skewers on a baking sheet lined with parchment paper",
    "Bake the skewers in the preheated oven for 12 minutes",
    "Sprinkle the dehydrated parsley over the skewers",
    "Serve the skewers in a bento box",
    "Garnish with lemon wedges"
  ],
