{
  "title": "Xtra Spicy British Fish Skewers",
  "description": "A pungent and romantic Cornish dish featuring chilli powder, perfect for a special occasion, made with dehydrated ingredients and no onion or garlic",
  "cuisine": "British",
  "diet": [
    "pescatarian",
    "gluten-free"
