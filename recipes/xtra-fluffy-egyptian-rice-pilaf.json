  "ingredients": [
    {
      "name": "Carnaroli rice",
      "amount": "1 cup",
      "notes": "rinsed and drained"
    },
    {
      "name": "water",
      "amount": "2 cups"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "black pepper",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "Ssam wrap",
      "amount": "4 sheets",
      "notes": "cut into strips"
    }
  ],
  "instructions": [
    "Heat the oil in a large saucepan over medium heat.",
    "Add the chopped onion and cook until softened, about 3 minutes.",
    "Add the garlic and cook for 1 minute, until fragrant.",
    "Add the rice and cook for 2 minutes, stirring constantly.",
    "Add the water, salt, and pepper, and bring to a boil.",
    "Reduce the heat to low, cover, and simmer for 15 minutes.",
    "Remove from heat and let it rest for 5 minutes.",
    "Fluff the rice with a fork and stir in the Ssam wrap strips.",
    "Serve hot and enjoy."
  ],
