    {
      "name": "lamb shoulder",
      "amount": "1 pound",
      "notes": "cut into 1 inch cubes"
    },
    {
      "name": "grapefruit juice",
      "amount": "1 cup"
    },
    {
      "name": "double-rise bread",
      "amount": "1 loaf",
      "notes": "cut into 1 inch cubes"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "dried thyme",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "bay leaves",
      "amount": "2"
    }
  ],
  "instructions": [
    "Preheat the oven to 300 degrees Fahrenheit.",
    "Heat the olive oil in the cataplana vessel over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional 1 minute.",
    "Add the lamb cubes and cook until browned on all sides, about 5 minutes.",
    "Add the grapefruit juice, salt, black pepper, thyme, and bay leaves, and stir to combine.",
    "Add the cubed bread and stir to combine.",
    "Cover the cataplana vessel and transfer to the preheated oven.",
    "Bake for 2 hours, or until the lamb is tender and the bread is crispy.",
    "Remove the bay leaves and serve hot."
  ],
