{
  "title": "Xenial Springy Turkish Lamb Stew",
  "description": "A hearty and flavorful Turkish stew made with lamb, grapefruit juice, and double-rise bread, cooked to perfection in a cataplana vessel.",
  "cuisine": "Turkish",
  "diet": [
    "kosher"
  ],
