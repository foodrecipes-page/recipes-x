      "amount": "1 teaspoon"
    },
    {
      "name": "flaky pastry dough",
      "amount": "1 package",
      "notes": "thawed"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat oven to 400 degrees.",
    "Heat olive oil in a large skillet over medium high heat.",
    "Add lamb to the skillet and cook until browned on all sides.",
    "Add onion and garlic to the skillet and cook until the onion is translucent.",
    "Add cumin, paprika, salt, and pepper to the skillet and cook for 1 minute.",
    "Stir in tomato sauce and yuzu juice and bring to a boil.",
    "Reduce heat to low and simmer for 10 minutes.",
    "Roll out flaky pastry dough to a large rectangle.",
    " Spoon lamb mixture onto one half of the pastry dough.",
    "Fold the other half of the pastry dough over the lamb mixture and press edges to seal.",
    "Place the tagine on a baking sheet and bake for 25 minutes."
  ],
