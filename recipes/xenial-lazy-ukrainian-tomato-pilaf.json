      "amount": "1 cup"
    },
    {
      "name": "grated carrot",
      "amount": "1/2 cup"
    },
    {
      "name": "chopped fresh dill",
      "amount": "1/4 cup"
    }
  ],
  "instructions": [
    "Heat the oil in a large saucepan over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the confit tomatoes, tomato paste, salt, and black pepper, and cook for 2 minutes.",
    "Add the rice to the saucepan and cook for 1 minute, stirring constantly.",
    "Add the water, canned diced tomatoes, and grated carrot to the saucepan, and bring to a boil.",
    "Reduce the heat to low, cover, and simmer for 20 minutes.",
    "Remove the saucepan from the heat and let it stand, covered, for 5 minutes.",
    "Fluff the pilaf with a fork and stir in the chopped fresh dill.",
    "Serve the pilaf hot, garnished with additional dill if desired."
  ],
