  "ingredients": [
    {
      "name": "chicken breast",
      "amount": "1 pound",
      "notes": "boneless and skinless"
    },
    {
      "name": "basil",
      "amount": "1/4 cup",
      "notes": "chopped fresh"
    },
    {
      "name": "coconut cream",
      "amount": "1/2 cup"
    },
    {
      "name": "empanada dough",
      "amount": "1 package",
      "notes": "homemade or store bought"
    },
    {
      "name": "egg",
      "amount": "1"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "olive oil",
      "amount": "1 tablespoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "In a large bowl, mix together the chicken breast, basil, coconut cream, salt, and black pepper.",
    "Roll out the empanada dough and cut out circles of dough.",
    "Place a tablespoon of the chicken mixture in the center of each dough circle.",
    "Brush the edges of the dough with the egg and fold the dough in half to form a half moon shape.",
    "Press the edges together to seal the empanada.",
    "Brush the tops of the empanadas with olive oil.",
    "Place the empanadas on a baking sheet lined with parchment paper and bake for 25 minutes."
  ],
