{
  "title": "Xtra Romantic Argentinian Chicken Empanadas",
  "description": "Earthy and romantic Argentinian dish featuring basil and coconut cream, perfect for a special occasion, this recipe is onion and garlic free.",
  "cuisine": "Argentinian",
  "diet": [
    "gluten-free",
