  "ingredients": [
    {
      "name": "plum tomatoes",
      "amount": "12",
      "notes": "ripe and sliced"
    },
    {
      "name": "cream cheese",
      "amount": "8 ounces",
      "notes": "softened"
    },
    {
      "name": "fry grind rice khao khuai",
      "amount": "1 cup",
      "notes": "cooked and cooled"
    },
    {
      "name": "butter",
      "amount": "4 tablespoons",
      "notes": "softened"
    },
    {
      "name": "white bread",
      "amount": "1 loaf",
      "notes": "thinly sliced"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon",
      "notes": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon",
      "notes": "to taste"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons",
      "notes": "freshly squeezed"
    }
  ],
  "instructions": [
    "Preheat the oven to 350 degrees Fahrenheit.",
    "Butter one side of each slice of bread.",
    "In a large bowl, mix together the cream cheese, cooked rice, salt, and black pepper until well combined.",
    "Add the sliced plum tomatoes to the bowl and mix gently.",
    "Spread a layer of the cream cheese mixture onto the unbuttered side of each bread slice.",
    "Top with a slice of buttered bread, butter side up.",
    "Place the sandwiches on a baking sheet and bake for 10 minutes, or until the bread is lightly toasted.",
    "Remove from the oven and sprinkle with chopped parsley and a squeeze of lemon juice.",
    "Serve immediately and enjoy."
  ],
