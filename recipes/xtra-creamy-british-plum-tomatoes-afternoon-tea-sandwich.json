{
  "title": "Xtra Creamy British Plum Tomatoes Afternoon Tea Sandwich",
  "description": "A creamy and bitter afternoon tea sandwich featuring plum tomatoes, perfect for a midnight craving, with a northern-irish twist and no onion or garlic",
  "cuisine": "British",
  "diet": [
    "vegetarian",
    "no onion no garlic"
  ],
