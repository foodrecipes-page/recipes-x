      "amount": "2 cups",
      "notes": "chilled"
    },
    {
      "name": "vegetable oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "finely chopped"
    },
    {
      "name": "ginger",
      "amount": "2 inches",
      "notes": "grated"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "cumin seeds",
      "amount": "1 teaspoon"
    },
    {
      "name": "coriander powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "turmeric powder",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "red chili powder",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "nutmeg powder",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Heat the oil in a large pan over medium heat.",
    "Add the cumin seeds and let them sizzle for a few seconds.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the grated ginger and minced garlic and cook for another minute.",
    "Add the coriander powder, turmeric powder, red chili powder, and salt, and cook for 1 minute.",
    "Pour in the chilled semi-skimmed milk and stir well.",
    "Bring the mixture to a simmer and let it cook for 10 minutes or until it thickens.",
    "Add the nutmeg powder and stir well.",
    "Reduce the heat to low and let it poach for 5 minutes.",
    "Serve hot and enjoy."
  ],
