      "amount": "1/2 teaspoon"
    },
    {
      "name": "cherry tomatoes",
      "amount": "1 cup",
      "notes": "halved"
    },
    {
      "name": "red onion",
      "amount": "1 cup",
      "notes": "sliced"
    }
