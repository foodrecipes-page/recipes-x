      "name": "beef chuck",
      "amount": "2 pounds",
      "notes": "cut into 1 1/2 inch cubes"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "carrots",
      "amount": "2 medium",
      "notes": "peeled and chopped"
    },
    {
      "name": "potatoes",
      "amount": "2 medium",
      "notes": "peeled and chopped"
    },
    {
      "name": "beef stock",
      "amount": "4 cups"
    },
    {
      "name": "tomato paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large Dutch oven over medium high heat.",
    "Add the beef cubes and cook until browned on all sides, about 5 minutes.",
    "Remove the browned beef from the pot and set aside.",
    "Add the chopped onion to the pot and cook until softened, about 5 minutes.",
    "Add the minced garlic to the pot and cook for 1 minute.",
    "Add the chopped carrots and potatoes to the pot and cook for 5 minutes.",
    "Add the beef stock, tomato paste, salt, and pepper to the pot and stir to combine.",
    "Return the browned beef to the pot and bring to a boil.",
    "Reduce the heat to low and simmer, covered, for 2 1/2 hours.",
    "Serve the stew hot, garnished with fresh herbs if desired."
  ],
