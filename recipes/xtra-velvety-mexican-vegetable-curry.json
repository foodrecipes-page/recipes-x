  "instructions": [
    "Heat oil in a large pan over medium heat.",
    "Add mustard seeds and let them sizzle for a few seconds.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and cook for another minute.",
    "Add the chopped carrots, zucchini, and red bell pepper, and cook for 5 minutes.",
    "Add the Italian seasoning and stir well.",
    "Pour in the coconut milk and bring the mixture to a boil.",
    "Reduce the heat to low and let it simmer for 10 minutes.",
    "Season with salt to taste.",
    "Serve hot over rice or with some naan bread."
  ],
