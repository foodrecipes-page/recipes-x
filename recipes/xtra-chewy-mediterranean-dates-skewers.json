      "amount": "1 tablespoon"
    },
    {
      "name": "olive oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "garlic",
      "amount": "2 cloves"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "wooden skewers",
      "amount": "12",
      "notes": "soaked in water for 30 minutes"
    }
  ],
  "instructions": [
    "Soak the wooden skewers in water for 30 minutes before preparing the dish.",
    "In a mortar, pound the garlic cloves until well crushed.",
    "Add the lemon juice, rum, olive oil, salt, and black pepper to the mortar and mix until well combined.",
    "Add the chopped parsley to the mortar and mix until the parsley is evenly distributed.",
    "Thread a date onto each wooden skewer.",
    "Brush the date with the mixture from the mortar.",
    "Repeat the process for the remaining dates.",
    "Serve the skewers immediately, or cover and refrigerate for up to 2 hours before serving."
  ],
