  "instructions": [
    "heat oil in a large dutch oven over medium-high heat",
    "cook shallots and garlic until fragrant, about 1 minute",
    "add ginger and cook for 1 minute",
    "add bell peppers and carrots and cook until they start to soften, about 3 minutes",
    "add bok choy and cook until it wilts, about 2 minutes",
    "add chili flakes and cook for 1 minute",
    "stir in soy sauce and coconut milk",
    "season with salt and pepper to taste",
    "reduce heat to medium-low and simmer for 5 minutes",
    "serve hot over rice or noodles"
