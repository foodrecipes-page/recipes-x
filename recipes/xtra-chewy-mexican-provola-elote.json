    {
      "name": "provola cheese",
      "amount": "1 cup shredded",
      "notes": "plant-based alternative"
    },
    {
      "name": "corn on the cob",
      "amount": "4 ears",
      "notes": "fresh"
    },
    {
      "name": "mayonnaise",
      "amount": "1/2 cup",
      "notes": "vegan"
    },
    {
      "name": "chili powder",
      "amount": "1 tsp"
    },
    {
      "name": "paprika",
      "amount": "1/2 tsp"
    },
    {
      "name": "lime juice",
      "amount": "2 tbsp"
    },
    {
      "name": "cilantro",
      "amount": "1/4 cup chopped",
      "notes": "fresh"
    },
    {
      "name": "garlic powder",
      "amount": "1/2 tsp"
    },
    {
      "name": "salt",
      "amount": "1/2 tsp"
    }
  ],
  "instructions": [
    "Preheat the broiler to 400 degrees Fahrenheit.",
    "Shuck the corn and remove the silk.",
    "In a large bowl, whisk together mayonnaise, chili powder, paprika, lime juice, garlic powder, and salt.",
    "Add the shredded provola cheese to the bowl and mix until well combined.",
    "Brush the mixture onto each ear of corn, making sure to coat all sides evenly.",
    "Place the corn on a baking sheet lined with parchment paper and broil for 10-12 minutes, turning every 2 minutes.",
    "Remove the corn from the oven and sprinkle with chopped cilantro.",
    "Serve immediately and enjoy."
  ],
