{
  "title": "Xtra Fresh Norwegian Chicken Skewers",
  "description": "A low-carb and refreshing Norwegian dish featuring Thai holy basil and katsuramuki-cut chicken, perfect for a post-workout meal.",
  "cuisine": "Norwegian",
