    {
      "name": "firm tofu",
      "amount": "1 block",
      "notes": "drained and cut into 1-inch cubes"
    },
    {
      "name": "red wine",
      "amount": "1 cup"
    },
    {
      "name": "ferment-kimchi",
      "amount": "1/2 cup",
      "notes": "chopped"
    },
    {
      "name": "coconut oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "curry powder",
      "amount": "2 teaspoons"
    },
    {
      "name": "turmeric",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Heat the coconut oil in a kadhai over medium heat",
    "Add the chopped onion and cook until softened, about 5 minutes",
    "Add the minced garlic and cook for an additional 1 minute",
    "Add the curry powder, turmeric, salt, and black pepper, and cook for 1 minute, stirring constantly",
    "Add the red wine and bring to a simmer",
    "Reduce the heat to low and let cook for 10 minutes, stirring occasionally",
    "Add the chopped ferment-kimchi and cook for an additional 2 minutes",
    "Add the cubed tofu and cook until heated through",
    "Serve the curry hot, garnished with fresh cilantro if desired"
  ],
