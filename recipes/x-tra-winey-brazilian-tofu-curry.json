{
  "title": "X-tra winey Brazilian tofu curry",
  "description": "A rich and flavorful Brazilian-inspired curry featuring tofu, ferment-kimchi, and a blend of spices, perfect for a winey date-night dinner",
  "cuisine": "Brazilian",
