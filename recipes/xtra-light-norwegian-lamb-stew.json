{
  "title": "Xtra Light Norwegian lamb Stew",
  "description": "A malty and light Norwegian stew featuring ginger and cooked to perfection in a clay pot, perfect for a romantic dinner",
  "cuisine": "Norwegian",
  "diet": [],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "lamb shoulder",
      "amount": "1 pound",
      "notes": "cut into 1 inch cubes"
    },
    {
      "name": "ginger",
      "amount": "2 inches",
      "notes": "peeled and sliced"
    },
    {
      "name": "malt syrup",
      "amount": "2 tablespoons"
    },
    {
      "name": "carrots",
      "amount": "2 medium",
      "notes": "peeled and sliced"
    },
    {
      "name": "potatoes",
      "amount": "2 medium",
      "notes": "peeled and cubed"
    },
    {
      "name": "onions",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "lamb broth",
      "amount": "2 cups"
    },
    {
      "name": "thyme",
      "amount": "1 teaspoon",
      "notes": "dried"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the oven to 300 degrees Fahrenheit",
    "Season the lamb cubes with salt, black pepper, and thyme",
    "Heat a couple of tablespoons of oil in the clay pot over medium heat",
    "Brown the lamb cubes in batches until they are browned on all sides",
    "Add the sliced ginger, chopped onions, and minced garlic to the pot and cook until the onions are translucent",
    "Add the sliced carrots and cubed potatoes to the pot and cook for a few minutes",
    "Add the malt syrup, lamb broth, and browned lamb cubes to the pot and stir to combine",
    "Cover the clay pot with a lid and transfer it to the preheated oven",
    "Bake the stew for 2 hours, or until the lamb is tender and the vegetables are cooked through",
    "Serve the stew hot, garnished with fresh herbs if desired"
  ],
