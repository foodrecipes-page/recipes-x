      "amount": "1 tsp"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "black pepper",
      "amount": "1/2 tsp"
    }
  ],
  "instructions": [
    "Cook the rice noodles according to package instructions and set aside.",
    "In a large skillet, heat the olive oil over medium heat.",
    "Add the minced garlic and cook for 1 minute until fragrant.",
    "Add the sliced cucumbers and cook for 2 minutes until slightly tender.",
    "In a small bowl, whisk together the soy sauce, sesame oil, salt, and black pepper.",
    "Pour the sauce over the cucumbers and garlic, and stir to combine.",
    "Add the cooked noodles to the skillet and toss to coat with the sauce.",
    "Serve hot and enjoy.",
    "Garnish with additional sliced cucumbers and garlic if desired."
  ],
