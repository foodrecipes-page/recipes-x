    {
      "name": "haddock fillets",
      "amount": "1 pound",
      "notes": "fresh or frozen, thawed"
    },
    {
      "name": "infused oil",
      "amount": "1/4 cup",
      "notes": "with garlic and herbs"
    },
    {
      "name": "onions",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "mushrooms",
      "amount": "1 cup",
      "notes": "sliced"
    },
    {
      "name": "polish sausage",
      "amount": "1/2 cup",
      "notes": "sliced, Jain-friendly"
    },
    {
      "name": "potatoes",
      "amount": "2 medium",
      "notes": "peeled, thinly sliced"
    },
    {
      "name": "vegetable broth",
      "amount": "1 cup",
      "notes": "low sodium"
    },
    {
      "name": "shredded cheese",
      "amount": "1 cup",
      "notes": "Jain-friendly, such as soy cheese"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit",
    "In a large skillet, heat the infused oil over medium heat",
    "Add the chopped onions and cook until they are translucent",
    "Add the sliced mushrooms and cook until they are tender",
    "Add the sliced polish sausage and cook for an additional 2 minutes",
    "In a large bowl, combine the cooked onion and mushroom mixture, haddock fillets, and sliced potatoes",
    "Pour the vegetable broth over the top of the mixture and stir to combine",
    "Transfer the mixture to a 9x13 inch baking dish and top with shredded cheese",
    "Bake the casserole in the preheated oven for 25-30 minutes, or until the cheese is melted and bubbly"
  ],
