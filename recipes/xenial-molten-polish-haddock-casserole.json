{
  "title": "Xenial Molten Polish Haddock Casserole",
  "description": "A hearty and comforting Polish-inspired casserole featuring haddock, infused oil, and Jain-friendly ingredients, perfect for a cozy dinner",
  "cuisine": "Polish",
  "diet": [
    "jain"
  ],
