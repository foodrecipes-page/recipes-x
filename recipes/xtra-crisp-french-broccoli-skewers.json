{
  "title": "Xtra Crisp French Broccoli Skewers",
  "description": "A sour and crisp French dish featuring purple sprouting broccoli, perfect for a midnight craving, with an ayurvedic-rajasic friendly twist.",
  "cuisine": "French",
  "diet": [
    "Vegetarian",
