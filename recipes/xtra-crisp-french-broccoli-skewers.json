      "name": "Purple sprouting broccoli",
      "amount": "1 bunch",
      "notes": "Cut into florets"
    },
    {
      "name": "Lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "Olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves",
      "notes": "Minced"
    },
    {
      "name": "Salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "Black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Paprika",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the robata grill to 400 degrees Fahrenheit.",
    "In a large bowl, whisk together lemon juice, olive oil, garlic, salt, black pepper, and paprika.",
    "Add the broccoli florets to the bowl and toss to coat with the marinade.",
    "Thread the marinated broccoli onto skewers, leaving a small space between each piece.",
    "Grill the skewers for 5-7 minutes per side, or until tender and slightly charred.",
    "Serve the skewers hot, garnished with additional lemon wedges if desired.",
    "Let the skewers cool for a few minutes before serving.",
    "Serve immediately and enjoy."
  ],
