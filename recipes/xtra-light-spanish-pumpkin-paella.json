  "instructions": [
    "Preheat the sous-vide machine to 180 degrees Fahrenheit.",
    "Heat the olive oil in a large skillet over medium heat.",
    "Add the smoked paprika and cook for 1 minute, stirring constantly.",
    "Add the pumpkin and cook until it starts to soften, about 5 minutes.",
    "Add the Arborio rice and cook for 1 minute, stirring constantly.",
    "Add the vegetable broth and bring to a boil.",
    "Transfer the mixture to a sous-vide bag and seal.",
    "Cook the paella in the sous-vide machine for 30 minutes.",
    "Crack in the eggs and stir gently to distribute.",
    "Season with salt to taste.",
    "Serve hot, garnished with chopped fresh parsley."
  ],
