{
  "title": "Xtra Dense Ukrainian Beef Pilaf",
  "description": "A buttery and dense Ukrainian dish featuring Thai red curry paste, perfect for meal prep. This nut-free-friendly recipe is cooked on a cedar plank.",
  "cuisine": "Ukrainian",
  "diet": [
    "gluten-free",
    "nut-free"
  ],
