  "ingredients": [
    {
      "name": "beef",
      "amount": "1 pound",
      "notes": "cut into small pieces"
    },
    {
      "name": "Thai red curry paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "butter",
      "amount": "4 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium"
    },
    {
      "name": "garlic",
      "amount": "3 cloves"
    },
    {
      "name": "rice",
      "amount": "2 cups"
    },
    {
      "name": "beef broth",
      "amount": "2 cups"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Preheat oven to 375 degrees.",
    "In a large bowl, mix together beef, curry paste, and butter until well combined.",
    "Add onion and garlic to the bowl and mix until the onion is translucent.",
    "Add rice, beef broth, salt, and pepper to the bowl and mix until the rice is well coated.",
    "Transfer the mixture to a cedar plank and shape into a rectangular pilaf.",
    "Bake the pilaf in the preheated oven for 45 minutes.",
    "Remove the pilaf from the oven and let it rest for 10 minutes.",
    "Slice the pilaf into individual portions and serve hot."
  ],
