    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "water",
      "amount": "1 cup"
    }
  ],
  "instructions": [
    "Heat the coconut oil in a pan over medium heat",
    "Add the chopped onion and cook until it is translucent",
    "Add the grated ginger and minced garlic and cook for 1 minute",
    "Add the curry powder and garam masala and cook for 1 minute",
    "Add the halved cherry tomatoes, lemon juice, salt, and water to the pan",
    "Stir well and bring the mixture to a boil",
    "Seal the pan and cook the curry in a sous-vide water bath at 180 degrees Fahrenheit for 30 minutes",
    "Remove the pan from the water bath and stir the curry",
    "Serve the curry hot over rice or with naan bread"
  ],
