      "amount": "1 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "chopped fresh cilantro",
      "amount": "1/4 cup",
      "notes": "optional"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium-high heat.",
    "Add the diced onion and cook until it is translucent, about 5 minutes.",
    "Add the garlic-infused oil, cumin, paprika, salt, and black pepper, and cook for 1 minute.",
    "Add the diced potatoes and cook for 10 minutes, stirring occasionally.",
    "Stir in the chopped ferment-kimchi and cook for an additional 2 minutes.",
    "Reduce heat to medium-low and simmer, covered, for 15 minutes, or until the potatoes are tender.",
    "Taste and adjust the seasoning as needed.",
    "Garnish with chopped fresh cilantro, if desired.",
    "Serve hot and enjoy."
  ],
