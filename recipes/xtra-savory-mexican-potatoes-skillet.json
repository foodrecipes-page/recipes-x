      "notes": "peeled and diced"
    },
    {
      "name": "ferment-kimchi",
      "amount": "1/2 cup",
      "notes": "chopped"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "diced"
    },
    {
      "name": "garlic-infused oil",
      "amount": "1 teaspoon"
    },
    {
