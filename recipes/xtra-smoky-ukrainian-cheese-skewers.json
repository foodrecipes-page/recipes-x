  "ingredients": [
    {
      "name": "Halloumi cheese",
      "amount": "12 oz",
      "notes": "cut into 1-inch cubes"
    },
    {
      "name": "Branston pickle",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "Fresh dill",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "Lemon juice",
      "amount": "2 tbsp"
    },
    {
      "name": "Olive oil",
      "amount": "1 tbsp"
    },
    {
      "name": "Garlic powder",
      "amount": "1 tsp"
    },
    {
      "name": "Smoked paprika",
      "amount": "1 tsp"
    },
    {
      "name": "Salt",
      "amount": "1/2 tsp"
    },
    {
      "name": "Black pepper",
      "amount": "1/4 tsp"
    },
    {
      "name": "Wooden skewers",
      "amount": "12",
      "notes": "soaked in water for 30 minutes"
    }
  ],
  "instructions": [
    "Preheat the binchotan grill to medium-high heat",
    "Thread a halloumi cheese cube, a few pieces of chopped branston pickle, and a sprinkle of chopped fresh dill onto each skewer",
    "In a small bowl, whisk together lemon juice, olive oil, garlic powder, smoked paprika, salt, and black pepper",
    "Brush the mixture onto both sides of the cheese and pickle on each skewer",
    "Place the skewers on the preheated grill and cook for 2-3 minutes per side, or until the cheese is golden brown and slightly charred",
    "Repeat with the remaining skewers",
    "Serve immediately and enjoy",
    "Let cool completely before storing in an airtight container in the refrigerator for up to 3 days"
  ],
