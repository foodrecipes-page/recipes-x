{
  "title": "Xtra Smoky Ukrainian Cheese Skewers",
  "description": "A citrusy, cheese-pull Ukrainian dish featuring branston-pickle and char-grill flavor, perfect for a low-glycemic meal prep snack",
  "cuisine": "Ukrainian",
  "diet": [
    "low-glycemic",
