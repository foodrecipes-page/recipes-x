      "name": "strawberries",
      "amount": "2 cups",
      "notes": "hulled and sliced"
    },
    {
      "name": "shio-cure",
      "amount": "1/4 cup",
      "notes": "mixed with 2 tablespoons water"
    },
    {
      "name": "corn husks",
      "amount": "4-6",
      "notes": "fresh or dried"
    },
    {
      "name": "feta cheese",
      "amount": "1/2 cup",
      "notes": "crumbly"
    },
    {
      "name": "kalamata olives",
      "amount": "1/4 cup",
      "notes": "pitted"
    },
    {
      "name": "red onion",
      "amount": "1/4 cup",
      "notes": "thinly sliced"
    },
    {
      "name": "cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Soak the corn husks in water for 30 minutes to make them pliable.",
    "In a bowl, mix together the sliced strawberries and shio-cure mixture.",
    "Add the crumbly feta cheese, pitted kalamata olives, thinly sliced red onion, and chopped cilantro to the bowl and stir to combine.",
    "Squeeze the lime juice over the mixture and sprinkle with salt.",
    "To assemble the wraps, lay a corn husk flat and spoon about 1/2 cup of the strawberry mixture onto the center of the husk.",
    "Fold the bottom edge of the husk up over the filling, then fold in the sides and roll the wrap up tightly.",
    "Repeat with the remaining ingredients.",
    "Serve immediately and enjoy."
  ],
