      "name": "Cod fish",
      "amount": "1 pound",
      "notes": "Cut into bite sized pieces"
    },
    {
      "name": "Mayonnaise",
      "amount": "1/2 cup"
    },
    {
      "name": "Dijon mustard",
      "amount": "2 tablespoons"
    },
    {
      "name": "Onion",
      "amount": "1 medium",
      "notes": "Chopped"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves",
      "notes": "Minced"
    },
    {
      "name": "Red bell pepper",
      "amount": "1 medium",
      "notes": "Chopped"
    },
    {
      "name": "Salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "Black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Fresh parsley",
      "amount": "1/4 cup",
      "notes": "Chopped"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large skillet over medium high heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and cook for 1 minute.",
    "Add the chopped red bell pepper and cook until it is tender.",
    "Add the cod fish pieces and cook until they are opaque and flake easily with a fork.",
    "In a small bowl, mix together the mayonnaise and Dijon mustard.",
    "Add the mayonnaise mixture to the skillet and stir to combine.",
    "Season with salt and black pepper to taste.",
    "Garnish with chopped fresh parsley and serve hot."
  ],
