      "amount": "1 pound",
      "notes": "peeled and deveined"
    },
    {
      "name": "Malaysian curry paste",
      "amount": "2 tablespoons",
      "notes": "use a reputable brand"
    },
    {
      "name": "Coconut oil",
      "amount": "2 tablespoons",
      "notes": "for sautéing"
    },
    {
      "name": "Xtra-hot red pepper flakes",
      "amount": "1 teaspoon",
      "notes": "adjust to taste"
    },
    {
